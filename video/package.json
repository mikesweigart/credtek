{
  "name": "credtek-video",
  "version": "1.0.0",
  "private": true,
  "description": "CredTek 60-second StoryBrand explainer (Remotion → MP4).",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "still": "remotion still src/index.ts CredTek60 out/still.png",
    "render": "remotion render src/index.ts CredTek60 out/credtek-60s.mp4 --codec=h264 --crf=18",
    "bed": "node scripts/make-bed.js",
    "web": "node scripts/web-optimize.js",
    "publish": "node scripts/publish-to-app.js",
    "all": "pnpm run bed && pnpm run render && pnpm run web && pnpm run publish",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.398",
    "@remotion/cli": "^4.0.398",
    "@remotion/google-fonts": "^4.0.398",
    "@remotion/renderer": "^4.0.398",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.398"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "ffmpeg-static": "^5.2.0",
    "typescript": "^5.4.5"
  }
}
