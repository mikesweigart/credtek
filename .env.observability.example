# Observability — copy these into Vercel project settings (or .env.local
# for dev). Every value is optional; missing keys make the SDK no-op so
# the app keeps building.

# ─── Sentry (error + performance tracking) ───────────────────────────
# Get the DSN from sentry.io → project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Optional: server-only DSN if you want to scope server errors
# separately from browser errors. Same DSN works for both.
SENTRY_DSN=

# Optional: needed for sourcemap upload during build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── PostHog (product analytics + funnel) ────────────────────────────
# Project API key from posthog.com → Project Settings → API Key
NEXT_PUBLIC_POSTHOG_KEY=

# Region (US default; switch to https://eu.i.posthog.com if your project
# is in the EU cluster)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Resend (already in use) ─────────────────────────────────────────
# RESEND_API_KEY=re_...
# CREDTEK_MAIL_FROM=CredTek <noreply@cred-tek.com>
# CREDTEK_FEEDBACK_TO=mikesweigart@yahoo.com
