# ============================================================
# CredTek — environment variables
# Copy to .env.local for local dev (gitignored). In production,
# set these in Vercel → Project → Settings → Environment Variables.
#
# NEXT_PUBLIC_* vars are inlined into the browser bundle AT BUILD TIME,
# so they must be set in Vercel BEFORE the build that uses them.
# ============================================================

# ---- Supabase (required) ----------------------------------
# From your project: Settings → API.
# If these are missing, /app renders a "Backend not configured" card
# instead of the product.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. Bypasses Row-Level Security.
# NEVER prefix with NEXT_PUBLIC. NEVER commit the real value.
# Without it: workspace self-heal, team invites, and intake-draft saves fail.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ---- Site (required in production) ------------------------
# Used to build absolute links in outbound email (e.g. intake resume links).
# Unset, the URL is derived from an unvalidated forwarded host header.
NEXT_PUBLIC_SITE_URL=https://cred-tek.com

# ---- Email / Resend (required in production) --------------
# Without RESEND_API_KEY, production email sends FAIL LOUDLY (by design —
# it used to silently report success while sending nothing). In local dev,
# a missing key falls back to console-log mode, which is fine.
RESEND_API_KEY=re_your_resend_key

# The verified sender. Defaults to Resend's sandbox address, which only
# delivers to the Resend account owner — set this once cred-tek.com is
# verified in Resend (SPF + DKIM).
CREDTEK_MAIL_FROM=CredTek <notifications@cred-tek.com>

# Where inbound notifications land. All default to a personal address —
# set them to real monitored inboxes before launch.
CREDTEK_FEEDBACK_TO=support@cred-tek.com
CREDTEK_LEADS_TO=sales@cred-tek.com
CREDTEK_INTAKE_TO=onboarding@cred-tek.com

# ---- Internal ops console (required in production) --------
# Comma-separated staff emails allowed into /ops/* (queue, audit, MARGIN).
# FAILS CLOSED: if unset in production, /ops returns 404 for everyone.
# Role is not usable as a gate here — every signed-in customer is "admin"
# within their own tenant.
CREDTEK_OPS_EMAILS=you@cred-tek.com,partner@cred-tek.com

# ---- Observability (optional) -----------------------------
# HIPAA note: session recording and DOM capture can ingest PHI. Leave
# PostHog unset (or disable recording) unless you have a BAA in place.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
