# ============================================================
# CredTek — environment variables
# Copy to .env.local for local dev (gitignored). In production,
# set these in Vercel → Project → Settings → Environment Variables.
# ============================================================

# Supabase — Phase 1 backend. From your project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret. Bypasses Row-Level Security.
# NEVER prefix with NEXT_PUBLIC. NEVER commit the real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
